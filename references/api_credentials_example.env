# YandexGPT
YANDEXGPT_API_KEY=your_api_key_here
YANDEX_IAM_TOKEN=your_iam_token_here
YANDEX_FOLDER_ID=your_folder_id

# CRM (Битрикс24)
BITRIX24_WEBHOOK_URL=https://your-domain.bitrix24.ru/rest/1/your_webhook/
BITRIX24_CLIENT_ID=your_client_id
BITRIX24_CLIENT_SECRET=your_client_secret

# CRM (amoCRM)
AMOCRM_CLIENT_ID=your_client_id
AMOCRM_CLIENT_SECRET=your_client_secret
AMOCRM_REDIRECT_URI=https://your-app.com/oauth/callback

# Telegram
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_PHONE_NUMBER=+70000000000

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_api_key

# MinIO
MINIO_ENDPOINT=minio.local:9000
MINIO_ACCESS_KEY=your_access_key
MINIO_SECRET_KEY=your_secret_key
